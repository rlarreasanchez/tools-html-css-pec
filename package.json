{
	"name": "tools-html-css-pec",
	"version": "1.0.0",
	"type": "module",
	"browserslist": "> 0.2%, last 10 years, not dead",
	"scripts": {
		"start": "npm-run-all clean parcel:dev",
		"build": "npm-run-all clean parcel:build",
		"parcel:dev": "parcel src/pages/*.html src/pages/**/*.html",
		"parcel:build": "parcel build src/pages/*.html src/pages/**/*.html",
		"clean": "rimraf dist .parcel-cache"
	},
	"keywords": [
		"html",
		"css",
		"parcel",
		"typescript",
		"sass",
		"posthtml",
		"postcss"
	],
	"author": "Rafael Larrea Sánchez",
	"license": "ISC",
	"description": "Proyecto académico de Implementación de un sitio web de recetas utilizando herramientas modernas: Parcel, TypeScript, Sass y PostHTML.",
	"devDependencies": {
		"@parcel/transformer-sass": "^2.16.4",
		"@types/node": "^25.3.5",
		"npm-run-all": "^4.1.5",
		"parcel": "^2.16.4",
		"postcss-normalize": "^13.0.1",
		"posthtml-expressions": "^1.11.4",
		"posthtml-include": "^2.0.1",
		"rimraf": "^6.1.3",
		"sass": "^1.97.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@fortawesome/fontawesome-free": "^7.2.0"
	}
}
